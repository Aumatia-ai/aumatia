# ── Supabase Self-Hosted (GCP) ──────────────────────────────────

# Project identifier (informational only)
NEXT_PUBLIC_SUPABASE_PROJECT_ID="self-hosted-gcp"

# Public Supabase URL — inlined by Next.js at build time
NEXT_PUBLIC_SUPABASE_URL="https://db.aumatia.com.co"

# Anon / Public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key_here"

# Service Role Key — NEVER commit the real value.
# Only used server-side for admin operations (register, storage, admin panel).
# In Cloud Run, set this as an environment variable in the service configuration.
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"
